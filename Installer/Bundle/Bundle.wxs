<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle Name="Black Hole Game"
          Version="1.0.0.0"
          Manufacturer="JoppeJoppinger"
          UpgradeCode="{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}"
          IconSourceFile="..\..\Resources\icon.ico">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
        LicenseFile="..\..\LICENSE.rtf"
        Theme="hyperlinkLicense"
        LogoFile="..\..\Resources\logo.png" />
    </BootstrapperApplication>

    <!-- Detect Git installation -->
    <util:RegistrySearch
      Id="GitInstalled"
      Root="HKLM"
      Key="SOFTWARE\GitForWindows"
      Value="InstallPath"
      Variable="GitInstallPath"
      Result="value" />

    <!-- Detect Visual C++ 2022 Redistributable -->
    <util:RegistrySearch
      Id="VCRedist2022Installed"
      Root="HKLM"
      Key="SOFTWARE\Microsoft\VisualStudio\14.0\VC\Runtimes\X64"
      Value="Installed"
      Variable="VCRedistInstalled"
      Result="value" />

    <!-- Detect Visual Studio 2022 Build Tools -->
    <util:RegistrySearch
      Id="VSBuildToolsInstalled"
      Root="HKLM"
      Key="SOFTWARE\Microsoft\VisualStudio\17.0"
      Value="InstallDir"
      Variable="VSInstallDir"
      Result="value" />

    <Chain>

      <!-- 1. Git for Windows (if not already installed) -->
      <ExePackage
        Id="GitForWindows"
        Name="Git for Windows"
        Description="Git version control system"
        DisplayName="Git for Windows 2.44.0"
        InstallCondition="NOT GitInstallPath"
        DetectCondition="GitInstallPath"
        DownloadUrl="https://github.com/git-for-windows/git/releases/download/v2.44.0.windows.1/Git-2.44.0-64-bit.exe"
        InstallArguments="/VERYSILENT /NORESTART /NOCANCEL /SP- /CLOSEAPPLICATIONS /RESTARTAPPLICATIONS /COMPONENTS=&quot;icons,ext\reg\shellhere,assoc,assoc_sh&quot;"
        UninstallArguments="/VERYSILENT /NORESTART"
        RepairArguments="/VERYSILENT /NORESTART"
        Cache="keep" />

      <!-- 2. Visual C++ 2022 Redistributable x64 -->
      <ExePackage
        Id="VCRedist2022x64"
        Name="Microsoft Visual C++ 2022 Redistributable (x64)"
        Description="Visual C++ runtime libraries"
        DisplayName="Microsoft Visual C++ 2022 Redistributable (x64)"
        InstallCondition="NOT VCRedistInstalled"
        DetectCondition="VCRedistInstalled = 1"
        DownloadUrl="https://aka.ms/vs/17/release/vc_redist.x64.exe"
        InstallArguments="/install /quiet /norestart"
        UninstallArguments="/uninstall /quiet /norestart"
        RepairArguments="/repair /quiet /norestart"
        Cache="keep" />

      <!-- 3. Visual Studio 2022 Build Tools (C++ Game workload) -->
      <ExePackage
        Id="VSBuildTools2022"
        Name="Visual Studio 2022 Build Tools"
        Description="C++ compilers and build tools required for UE5"
        DisplayName="Visual Studio 2022 Build Tools"
        InstallCondition="NOT VSInstallDir"
        DetectCondition="VSInstallDir"
        DownloadUrl="https://aka.ms/vs/17/release/vs_buildtools.exe"
        InstallArguments="--quiet --wait --norestart --nocache --add Microsoft.VisualStudio.Workload.VCTools --add Microsoft.VisualStudio.Component.VC.Tools.x86.x64 --add Microsoft.VisualStudio.Component.Windows11SDK.22621"
        UninstallArguments="--quiet --wait --norestart --uninstall"
        Cache="keep" />

      <!-- 4. Main BlackHoleGame MSI -->
      <MsiPackage
        Id="BlackHoleGameMsi"
        Name="Black Hole Game"
        Description="Black Hole Game UE5 project files"
        DisplayName="Black Hole Game 1.0.0"
        SourceFile="..\Output\BlackHoleGame-1.0.0.msi"
        Visible="yes"
        Cache="keep">
        <MsiProperty Name="INSTALLFOLDER" Value="[InstallFolder]" />
      </MsiPackage>

    </Chain>

  </Bundle>
</Wix>
